{
  "name": "wa-worker",
  "version": "0.0.1",
  "description": "Worker isolado de WhatsApp/Baileys — consome jobs do BullMQ, publica eventos via Redis Pub/Sub. Roda separado do bot-api para isolar o plano de dados WhatsApp do plano HTTP.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@supabase/supabase-js": "^2.105.4",
    "@whiskeysockets/baileys": "7.0.0-rc10",
    "async-mutex": "^0.5.0",
    "bullmq": "^5.62.0",
    "ioredis": "^5.10.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.7.0",
    "prisma": "^7.8.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@whiskeysockets/baileys",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
